// Nextflow configuration

params {
    // Required parameters (must be set by user)
    data_path = null
    sections = null
    
    // Resegmentation parameters
    factor = 0.2
    diam = 50
    
    // Proseg parameters
    cellpose_scale = 0.2125
    prior_seg_reassignment_prob = 0.5
    
    // Resource parameters
    n_cores = 12
    n_gb = 32
}

// Process configuration
process {
    // Default resources
    cpus = params.n_cores
    memory = "${params.n_gb} GB"
    
    // Specific process configurations
    withName: RESEGMENT {
        conda = 'cellpose scikit-image tifffile numpy scipy'
        // GPU access for cellpose
        accelerator = 1
        clusterOptions = '--gres=gpu:1'
    }
    
    withName: PROSEG_REFINE {
        conda = 'proseg'
    }
    
    withName: XENIUMRANGER_IMPORT {
        conda = 'xeniumranger'
    }
}

// Execution profiles
profiles {
    standard {
        process.executor = 'local'
    }
    
    slurm {
        process {
            executor = 'slurm'
            queue = 'gpu'
            time = '4h'
        }
    }
    
    conda {
        conda.enabled = true
        conda.useMamba = true
    }
    
    docker {
        docker.enabled = true
        process.container = 'your-docker-image:latest'
    }
}

// Resource limits
executor {
    queueSize = 10
    pollInterval = '30 sec'
}

// Cleanup
cleanup = true